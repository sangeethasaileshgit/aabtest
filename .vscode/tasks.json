		{
			"label": "Check Disk Space",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-Command",
				"Get-PSDrive C | Format-List Used, Free; [math]::Round((Get-PSDrive C).Free/1GB,2)"
			],
			"isBackground": false
		},
		{
			"label": "Clean Gradle Caches",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-Command",
				"Remove-Item -Path \"$env:USERPROFILE\\.gradle\\caches\\8.10.2\" -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item -Path \"$env:USERPROFILE\\.gradle\\caches\\transforms-*\" -Recurse -Force -ErrorAction SilentlyContinue; Remove-Item -Path \"$env:USERPROFILE\\.gradle\\daemon\\8.10.2\" -Recurse -Force -ErrorAction SilentlyContinue; Write-Output 'Cleaned old Gradle caches'; [math]::Round((Get-PSDrive C).Free/1GB,2)"
			],
			"isBackground": false
		},
