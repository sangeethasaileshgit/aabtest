{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Build Flutter APK",
			"type": "shell",
			"command": "flutter",
			"args": [
				"build",
				"apk"
			],
			"isBackground": false
		},
		{
			"label": "Kill Web Port 8090",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-Command",
				"$connections = Get-NetTCPConnection -LocalPort 8090 -ErrorAction SilentlyContinue; if ($connections) { $connections | ForEach-Object { Stop-Process -Id $_.OwningProcess -Force -ErrorAction SilentlyContinue }; Write-Output 'Freed port 8090'; } else { Write-Output 'Port 8090 already free'; }"
			],
			"isBackground": false
		},
		{
			"label": "Run Flutter Chrome",
			"type": "shell",
			"command": "flutter",
			"args": [
				"run",
				"-d",
				"chrome"
			],
			"isBackground": true
		},
